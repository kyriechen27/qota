# Copy to `.dev.vars` for local `wrangler dev`. Do NOT commit `.dev.vars`.
# Generate JWT_SECRET via:  openssl rand -hex 32

JWT_SECRET="change-me-to-a-long-random-string-32bytes-min"

# в”Ђв”Ђв”Ђ Storage в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# `wrangler dev` emulates Cloudflare and has no local disk, so it ALWAYS needs a
# bucket вЂ” fill in the R2 (or S3) credentials below.
#
# Local Node dev (`npm run dev:node`) does NOT need these: with them blank, qota
# stores files in a local folder (apps/worker/data/blobs) by default. To point
# Node dev at MinIO/S3 instead, set S3_ENDPOINT + S3_ACCESS_KEY_ID +
# S3_SECRET_ACCESS_KEY (see DEPLOY.md).

# Cloudflare R2 S3-compatible credentials. Create them under:
#   Cloudflare dashboard в†’ R2 в†’ Manage R2 API Tokens в†’ Create API token
# Permission: Object Read & Write, scoped to bucket qota-ota.
R2_ACCESS_KEY_ID="REPLACE_ME"
R2_SECRET_ACCESS_KEY="REPLACE_ME"
