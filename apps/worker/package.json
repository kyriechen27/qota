{
  "name": "@qota/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --persist-to .wrangler/state",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "build:node": "esbuild node/server.mjs --bundle --platform=node --format=esm --target=node18 --outfile=dist-node/server.mjs --external:better-sqlite3",
    "start:node": "node dist-node/server.mjs",
    "dev:node": "tsx watch node/server.mjs",
    "db:migrate:local": "wrangler d1 migrations apply qota-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply qota-db --remote",
    "db:reset:local": "rm -rf .wrangler/state/v3/d1 && wrangler d1 migrations apply qota-db --local",
    "seed": "node ./scripts/seed.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@qota/shared": "*",
    "aws4fetch": "^1.0.20",
    "better-sqlite3": "^11.5.0",
    "hono": "^4.6.10",
    "pinyin-pro": "^3.28.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241112.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "wrangler": "^3.86.0"
  }
}
