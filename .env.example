# Copy to .env for `docker compose up`. Do NOT commit .env.

# REQUIRED — JWT signing secret. Generate with: openssl rand -hex 32
JWT_SECRET=

# First-run admin (created only when the database has no users yet).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# ─── Storage ──────────────────────────────────────────────────────────────────
# Default (S3_* left blank): files are stored in a LOCAL FOLDER inside the
# qota-data volume (/app/data/blobs). No MinIO/S3 required — just `docker compose up`.
#
# To use the bundled MinIO (or any S3/R2) instead, uncomment the block below and
# start with the minio profile:
#   docker compose --profile minio up -d --build
#
# STORAGE_DRIVER=s3
# S3_ACCESS_KEY_ID=qotaadmin
# S3_SECRET_ACCESS_KEY=qotasecret123
# S3_BUCKET=qota-ota
# S3_ENDPOINT=http://minio:9000
# # Endpoint baked into URLs handed to the browser / devices. Must be reachable
# # by THEM. Local: http://localhost:9000. Server: your public MinIO/S3 URL.
# S3_PUBLIC_ENDPOINT=http://localhost:9000
