# Copy to .env for `docker compose up`. Do NOT commit .env.

# REQUIRED — JWT signing secret. Generate with: openssl rand -hex 32
JWT_SECRET=

# First-run admin (created only when the database has no users yet).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# Object storage (MinIO defaults below work out of the box for local use).
S3_BUCKET=qota-ota
S3_ACCESS_KEY_ID=qotaadmin
S3_SECRET_ACCESS_KEY=qotasecret123
# Endpoint baked into presigned URLs handed to the browser / devices.
# Must be reachable by THEM. For local use that's the host's MinIO port.
# For a server, set this to your public MinIO/S3 URL (e.g. https://s3.example.com).
S3_PUBLIC_ENDPOINT=http://localhost:9000
