{
  "name": "qota",
  "version": "0.1.0",
  "private": true,
  "description": "OTA package version management on Cloudflare Workers + Pages + R2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:worker dev:web",
    "dev:worker": "npm -w apps/worker run dev",
    "dev:web": "npm -w apps/web run dev",
    "dev:node": "npm-run-all -p dev:node:worker dev:node:web",
    "dev:node:worker": "npm -w apps/worker run dev:node",
    "dev:node:web": "VITE_API_PROXY=http://127.0.0.1:8080 npm -w apps/web run dev",
    "build": "npm -w apps/web run build",
    "deploy:worker": "npm -w apps/worker run deploy",
    "deploy:web": "npm -w apps/web run deploy",
    "pages:dev": "npm run build && wrangler pages dev",
    "pages:deploy": "npm run build && wrangler pages deploy",
    "d1:migrate:local": "wrangler d1 migrations apply qota-db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply qota-db --remote",
    "db:migrate:local": "npm -w apps/worker run db:migrate:local",
    "db:migrate:remote": "npm -w apps/worker run db:migrate:remote",
    "seed": "npm -w apps/worker run seed",
    "typecheck": "npm -w apps/worker run typecheck && npm -w apps/web run typecheck"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.18"
  }
}
