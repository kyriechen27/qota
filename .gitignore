# Dependencies
node_modules

# Build / compilation output
dist
dist-node
build
*.tsbuildinfo

# Cloudflare Pages deploy artifacts ARE committed (empty-build-command deploy,
# like remote-file). Rebuilt by `npm run pages:build`. Source maps stay ignored.
!apps/web/dist/
!apps/web/dist/**
apps/web/dist/**/*.map

# Cloudflare Wrangler / Miniflare
.wrangler
.miniflare

# Local runtime data (D1 / SQLite)
apps/worker/data/
*.db
*.db-shm
*.db-wal
*.sqlite

# Secrets & local env
.dev.vars
.dev.vars.*
!.dev.vars.example
.env
.env.*
!.env.example

# Caches & coverage
.cache
coverage

# Logs
*.log

# OS files
.DS_Store

# Editors
.vscode/*
!.vscode/extensions.json
.idea
